default_platform(:android)

platform :android do

  # ── Ejecutar tests unitarios ──────────────────────────────────────────────
  lane :test do
    sh("cd .. && npm test -- --watchAll=false")
  end

  # ── Build debug (APK para pruebas) ────────────────────────────────────────
  lane :build_debug do
    gradle(
      task: "assembleDebug",
      project_dir: "android/"
    )
  end

  # ── Build release (APK firmado) ───────────────────────────────────────────
  lane :build_release do
    gradle(
      task: "assembleRelease",
      project_dir: "android/",
      properties: {
        "android.injected.signing.store.file"     => ENV["KEYSTORE_PATH"],
        "android.injected.signing.store.password" => ENV["KEYSTORE_PASSWORD"],
        "android.injected.signing.key.alias"      => ENV["KEY_ALIAS"],
        "android.injected.signing.key.password"   => ENV["KEY_PASSWORD"],
      }
    )
  end

  # ── Lint + tests + build debug en un solo pipeline ────────────────────────
  lane :ci do
    sh("cd .. && npm run test -- --watchAll=false --ci")
    build_debug
  end

end

platform :ios do

  lane :test do
    sh("cd .. && npm test -- --watchAll=false")
  end

end
